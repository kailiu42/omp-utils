[Unit]
Description=OMP stats dashboard
Documentation=https://omp.sh

[Service]
Type=simple
WorkingDirectory=%h
Environment=PATH=%h/bin:%h/.bun/bin:%h/.local/bin:/usr/local/bin:/usr/bin:/bin
ExecStart=/usr/bin/env omp stats --port 3847
Restart=always
RestartSec=5
RuntimeMaxSec=4h

[Install]
WantedBy=default.target

