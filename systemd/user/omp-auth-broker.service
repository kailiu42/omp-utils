[Unit]
Description=OMP auth broker
Documentation=https://omp.sh

[Service]
Type=simple
WorkingDirectory=%h
Environment=PATH=%h/bin:%h/.bun/bin:%h/.local/bin:/usr/local/bin:/usr/bin:/bin
ExecStart=/usr/bin/env omp auth-broker serve --bind 127.0.0.1:8765
Restart=always
RestartSec=5
RuntimeMaxSec=4h

[Install]
WantedBy=default.target

